# VAYU Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .enc.example .env

# ── Required for AI chatbot & enforcement notices ─────────
GROQ_API_KEY=
# Get a free key at: https://console.groq.com

# ── Required for live air quality + weather data ──────────
OPENWEATHER_API_KEY=
# Get a free key at: https://openweathermap.org/api
# Free tier: 1,000 calls/day — enough for all 6 cities at 15-min refresh

# ── Supabase (replaces local PostgreSQL / SQLite) ─────────
SUPABASE_URL=
# Project URL from: https://supabase.com/dashboard → Project Settings → API

SUPABASE_ANON_KEY=
# anon/public key — for read-only client access

SUPABASE_SERVICE_KEY=
# service_role key — for backend writes (keep secret, never expose in frontend)

# ── Optional: Google Earth Engine (Sentinel-5P satellite) ─
GEE_PROJECT=

# ── Optional: WhatsApp citizen alerts via Twilio ──────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Run supabase.sql in Supabase SQL Editor after creating your project
