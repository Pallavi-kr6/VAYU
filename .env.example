# VAYU Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── Required for AI chatbot & enforcement notices ─────────
GROQ_API_KEY=
# Get a free key at: https://console.groq.com

# ── Required for live weather (temp, humidity, wind, rain) ─
OPENWEATHER_API_KEY=
# Get a free key at: https://openweathermap.org/api

# ── Required for live AQI + pollutants (WAQI) ───────────
WAQI_API_KEY=
# Get a free token at: https://aqicn.org/data-platform/token/

# ── Supabase (optional persistence) ───────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Optional: Google Earth Engine (Sentinel-5P satellite) ─
GEE_PROJECT=

# ── Optional: WhatsApp citizen alerts via Twilio ──────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
