# VAYU Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── Required for AI chatbot & enforcement notices ─────────
GROQ_API_KEY=
# Get a free key at: https://console.groq.com

# ── Required for live weather (temp, humidity, wind, rain) ─
OPENWEATHER_API_KEY=
# Get a free key at: https://openweathermap.org/api

# ── Required for live AQI + pollutants (WAQI) ───────────
WAQI_API_KEY=
# Get a free token at: https://aqicn.org/data-platform/token/

# ── Supabase (optional persistence) ───────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Optional: Google Earth Engine (Sentinel-5P satellite) ─
GEE_PROJECT=

# ── Optional: Geospatial intelligence layer toggles ──────
ENABLE_SENTINEL=true
ENABLE_NASA_FIRMS=true
ENABLE_OSM=true

SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
NASA_FIRMS_API_KEY=
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Optional: WhatsApp citizen alerts via Twilio ──────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SENTINEL_CLIENT_ID=your_primary_sentinel_id
SENTINEL_CLIENT_SECRET=your_primary_sentinel_secret
SENTINEL_CLIENT_ID_FALLBACK=your_backup_sentinel_id
SENTINEL_CLIENT_SECRET_FALLBACK=your_backup_sentinel_secret

NASA_FIRMS_API_KEY=your_primary_nasa_key
NASA_FIRMS_API_KEY_FALLBACK=your_backup_nasa_key